{
    // 原 base + app 两子项目已合并为单体 sjgtv 项目
    // 迁移：app 运行配置 → sjgtv（cwd 为项目根）；base/app 的 tool 脚本（gen_export、gen_l10n_*、scan_*）已无对应 .dart，由 flutter gen-l10n、build_runner、check_project.sh 等替代
    "version": "0.2.0",
    "configurations": [
        // ========== sjgtv 应用运行（由原 app 迁移） ==========
        {
            "name": "sjgtv (debug)",
            "request": "launch",
            "type": "dart"
        },
        {
            "name": "sjgtv (debug, noDebug)",
            "request": "launch",
            "type": "dart",
            "noDebug": true
        },
        {
            "name": "sjgtv (profile)",
            "request": "launch",
            "type": "dart",
            "flutterMode": "profile"
        },
        {
            "name": "sjgtv (profile, noDebug)",
            "request": "launch",
            "type": "dart",
            "flutterMode": "profile",
            "noDebug": true
        },
        {
            "name": "sjgtv (release)",
            "request": "launch",
            "type": "dart",
            "flutterMode": "release"
        },
        {
            "name": "sjgtv (release, noDebug)",
            "request": "launch",
            "type": "dart",
            "flutterMode": "release",
            "noDebug": true
        }
    ]
}
